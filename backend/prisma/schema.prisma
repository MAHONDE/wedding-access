generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN_VIN_HONNEUR
  AGENT_VIN_HONNEUR
  AGENT_DINER
}

enum CeremonyType {
  VIN_HONNEUR
  DINER
}

enum GuestType {
  INDIVIDUAL
  COUPLE
}

enum EntryStatus {
  NOT_ARRIVED
  ARRIVED
}

enum ScanResult {
  VALID
  INVALID
  ALREADY_USED
  WRONG_CEREMONY
}

enum InvitationStatus {
  GENERATED
  SENT_WHATSAPP
  SENT_BLUETOOTH
  NOT_SENT
  OBSOLETE
}

enum TableShape {
  ROUND
  RECTANGULAR
  SQUARE
}

enum SeatingSourceType {
  MANUAL
  GENERATED_FROM_PHOTO
}

model User {
  id            String        @id @default(cuid())
  email         String        @unique
  passwordHash  String
  firstName     String
  lastName      String
  role          Role
  ceremonyScope CeremonyType?
  isActive      Boolean       @default(true)
  scanLogs      ScanLog[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Ceremony {
  id           String        @id @default(cuid())
  name         String
  type         CeremonyType  @unique
  description  String?
  date         DateTime
  location     String?
  guests       Guest[]
  tables       Table[]
  templates    Template[]
  invitations  Invitation[]
  scanLogs     ScanLog[]
  seatingPlans SeatingPlan[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model AppBranding {
  id              String   @id @default(cuid())
  appName         String   @default("Wedding Access")
  monogramPath    String?
  monogramData    String?
  monogramMime    String?
  primaryLogoPath String?
  logoData        String?
  logoMime        String?
  activeThemeMode String?
  updatedByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Guest {
  id            String       @id @default(cuid())
  ceremonyId    String
  ceremony      Ceremony     @relation(fields: [ceremonyId], references: [id])
  type          GuestType    @default(INDIVIDUAL)
  primaryName   String
  companionName String?
  email         String?
  phone         String?
  numberOfSeats Int          @default(1)
  tableId       String?
  table         Table?       @relation(fields: [tableId], references: [id])
  entryStatus   EntryStatus  @default(NOT_ARRIVED)
  qrCodes       QRCode[]
  invitations   Invitation[]
  scanLogs      ScanLog[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  deletedAt     DateTime?
}

model QRCode {
  id          String       @id @default(cuid())
  guestId     String
  guest       Guest        @relation(fields: [guestId], references: [id])
  ceremonyId  String
  token       String       @unique
  qrImagePath String?
  isActive    Boolean      @default(true)
  generatedAt DateTime     @default(now())
  lastUsedAt  DateTime?
  invitations Invitation[]
}

model Template {
  id           String       @id @default(cuid())
  ceremonyId   String
  ceremony     Ceremony     @relation(fields: [ceremonyId], references: [id])
  name         String
  filePath     String
  isActive     Boolean      @default(true)
  qrZoneConfig Json?
  placeholders Json?
  invitations  Invitation[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model Invitation {
  id                          String           @id @default(cuid())
  guestId                     String
  guest                       Guest            @relation(fields: [guestId], references: [id])
  ceremonyId                  String
  ceremony                    Ceremony         @relation(fields: [ceremonyId], references: [id])
  qrCodeId                    String
  qrCode                      QRCode           @relation(fields: [qrCodeId], references: [id])
  templateId                  String?
  template                    Template?        @relation(fields: [templateId], references: [id])
  pdfPath                     String?
  fileName                    String?
  status                      InvitationStatus @default(NOT_SENT)
  isObsolete                  Boolean          @default(false)
  regeneratedFromInvitationId String?
  generatedAt                 DateTime         @default(now())
  updatedAt                   DateTime         @updatedAt
}

model Table {
  id             String     @id @default(cuid())
  ceremonyId     String
  ceremony       Ceremony   @relation(fields: [ceremonyId], references: [id])
  name           String
  numberOfChairs Int        @default(10)
  positionX      Float?
  positionY      Float?
  shape          TableShape @default(ROUND)
  guests         Guest[]
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

model SeatingPlan {
  id              String            @id @default(cuid())
  ceremonyId      String
  ceremony        Ceremony          @relation(fields: [ceremonyId], references: [id])
  name            String
  planData        Json              @default("{}")
  sourceType      SeatingSourceType @default(MANUAL)
  sourcePhotoPath String?
  pdfPath         String?
  roomPhotos      RoomPhoto[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
}

model RoomPhoto {
  id            String      @id @default(cuid())
  seatingPlanId String
  seatingPlan   SeatingPlan @relation(fields: [seatingPlanId], references: [id])
  filePath      String
  uploadedAt    DateTime    @default(now())
}

model ScanLog {
  id              String     @id @default(cuid())
  guestId         String?
  guest           Guest?     @relation(fields: [guestId], references: [id])
  ceremonyId      String?
  ceremony        Ceremony?  @relation(fields: [ceremonyId], references: [id])
  qrToken         String
  scannedByUserId String
  scannedBy       User       @relation(fields: [scannedByUserId], references: [id])
  result          ScanResult
  scannedAt       DateTime   @default(now())
  deviceInfo      String?
}
