# ─── Database ──────────────────────────────────────────────
POSTGRES_DB=wedding_access
POSTGRES_USER=wa_user
POSTGRES_PASSWORD=changeme_in_production

# ─── Backend ───────────────────────────────────────────────
DATABASE_URL=postgresql://wa_user:changeme_in_production@localhost:5432/wedding_access

# IMPORTANT: Generate strong random secrets for production:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change_this_jwt_secret_in_production
JWT_EXPIRES_IN=8h
QR_SECRET=change_this_qr_secret_in_production

STORAGE_PATH=/app/storage
PORT=3000

# ─── Frontend ──────────────────────────────────────────────
FRONTEND_PORT=8080
